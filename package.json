{
  "name": "protect-my-env",
  "displayName": "Protect My Env",
  "description": "Protects your .env files from accidental screen exposure.",
  "version": "0.1.3",
  "publisher": "marcuspmd",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcuspmd/protect-my-env"
  },
  "bugs": {
    "url": "https://github.com/marcuspmd/protect-my-env/issues"
  },
  "homepage": "https://github.com/marcuspmd/protect-my-env#readme",
  "license": "MIT",
  "keywords": [
    "env",
    "dotenv",
    "security",
    "secrets",
    "mask",
    "privacy",
    "environment variables"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Protect My Env",
      "properties": {
        "protectMyEnv.obfuscationMode": {
          "type": "string",
          "enum": [
            "all",
            "pattern"
          ],
          "default": "all",
          "description": "Whether to obfuscate all environment variables or only those matching specific rules and patterns."
        },
        "protectMyEnv.patterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "*_SECRET",
            "*_KEY",
            "*_PASSWORD",
            "*_TOKEN",
            "PASSWORD",
            "SECRET",
            "TOKEN",
            "KEY"
          ],
          "description": "Glob patterns to obfuscate when mode is 'pattern' (e.g. *_SECRET, *_KEY). Case-insensitive."
        },
        "protectMyEnv.rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Specific environment variable keys to always obfuscate."
        },
        "protectMyEnv.maskCharacter": {
          "type": "string",
          "default": "•",
          "description": "Character used to mask the environment variable value."
        },
        "protectMyEnv.maskLength": {
          "type": "number",
          "default": 8,
          "description": "Fixed length of the masked text. Set to 0 to match the exact length of the original value."
        },
        "protectMyEnv.protectComments": {
          "type": "boolean",
          "default": false,
          "description": "Whether to also mask comments (full line and inline comments) in .env files."
        }
      }
    },
    "commands": [
      {
        "command": "protectMyEnv.revealAll",
        "title": "Reveal All Values",
        "icon": "$(eye)"
      },
      {
        "command": "protectMyEnv.hideAll",
        "title": "Hide All Values",
        "icon": "$(eye-closed)"
      }
    ],
    "customEditors": [
      {
        "viewType": "protectMyEnv.secureEnvEditor",
        "displayName": "Protect My Env Secure Editor",
        "selector": [
          {
            "filenamePattern": "*.env"
          },
          {
            "filenamePattern": "*.env.*"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "protectMyEnv.revealAll",
          "when": "resourceFilename =~ /\\.(env|env\\..*)$/ && !protectMyEnv.allRevealed",
          "group": "navigation"
        },
        {
          "command": "protectMyEnv.hideAll",
          "when": "resourceFilename =~ /\\.(env|env\\..*)$/ && protectMyEnv.allRevealed",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "node esbuild.js",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.11.18",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0"
  }
}
